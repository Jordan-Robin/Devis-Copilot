{
  "model": "sonnet",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd /home/jordan/Documents/copilot-devis && FILE=$(jq -r '.tool_input.file_path // empty'); case \"$FILE\" in *.ts|*.tsx) npx tsc --noEmit 2>&1 | head -30 ;; esac",
            "timeout": 30,
            "statusMessage": "Vérification TypeScript..."
          }
        ]
      }
    ]
  },
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.*.local)",
      "Edit(.env)",
      "Edit(.env.local)",
      "Edit(.env.*.local)",
      "Bash(cat .env*)",
      "Bash(echo $OPENAI*)",
      "Bash(echo $GOOGLE*)",
      "Bash(echo $GITHUB*)"
    ]
  }
}
